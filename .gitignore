# Composer
/vendor/
composer.lock

# Logs
*.log
*.txt
# RAG sample documents are distribution-tracked despite the global *.txt rule
!docs/rag-samples/*.txt

# Cache
cache/
tmp/*
!tmp/.htaccess
temp/
.phpunit.result.cache

*.csv

# PHP session files — stored in storage/sessions/ (outside webroot-exposed tmp/)
storage/sessions/*

# IDE
.vscode/
.idea/
*.swp

# System files
.DS_Store
Thumbs.db

# PHPStorm
*.iml

# Environment files
.env
.env.local
.env.*.local

# Config json (instance-specific — except migrations.json which is distribution-tracked)
config/*.json
!config/migrations.json
includes/php.ini

# Auto-generated IP hash salt — host-specific secret, must not be committed
includes/.secret_salt

# CodeSniffer
phpcs.phar
phpcbf.phar

# Python
__pycache__/
*.py
*.pyc
*.bak

# Files storage
storage/files/*
!storage/files/.gitkeep

# Runtime ratelimit state
storage/ratelimit/*
!storage/ratelimit/.htaccess

# Files claude
/.claude
CLAUDE.md

# Cypress — commit test files & docs, ignore generated artifacts
cypress/screenshots/
cypress/videos/
cypress/downloads/
.cypress-cache/
node_modules/

# Dependencies — commit package*.json for reproducibility
# package.json
# package-lock.json
