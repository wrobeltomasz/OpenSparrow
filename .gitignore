# Composer — composer.lock is committed so CI installs reproducible dev-dependency versions
/vendor/

# Logs
*.log

# Stray data exports — scoped to the repo root only (the storage/ tree is
# ignored wholesale below). Avoids blanket *.txt / *.csv globs that silently
# untracked legitimate files such as docs/rag*/*.txt and cypress fixtures.
/*.txt
/*.csv

# Cache
cache/
temp/
.phpunit.result.cache

# PHP session files — stored in storage/sessions/ (keep the dir placeholder + web-deny guard)
storage/sessions/*
!storage/sessions/.gitkeep
!storage/sessions/.htaccess

# IDE
.vscode/
.idea/
*.swp

# System files
.DS_Store
Thumbs.db

# PHPStorm
*.iml

# Environment files
.env
.env.local
.env.*.local

# Config json (instance-specific — except migrations.json which is distribution-tracked)
config/*.json
!config/migrations.json
includes/php.ini

# Auto-generated IP hash salt — host-specific secret, must not be committed
includes/.secret_salt

# Auto-generated symmetric encryption key for secrets stored in spw_config
includes/.secret_key

# CodeSniffer
phpcs.phar
phpcbf.phar

# Python
__pycache__/
*.py
# keep tracked helper scripts (the *.py blanket above would otherwise drop them)
!scripts/*.py
*.pyc
*.bak

# Files storage
storage/files/*
!storage/files/.gitkeep
!storage/files/.htaccess

# Runtime ratelimit state
storage/ratelimit/*
!storage/ratelimit/.htaccess

# Uploaded custom logo (admin → Settings → Custom Logo)
public/assets/img/uploads/*
!public/assets/img/uploads/.gitkeep
!public/assets/img/uploads/.htaccess

# Files claude
/.claude
CLAUDE.md

# Cypress — commit test files & docs, ignore generated artifacts
cypress/screenshots/
cypress/videos/
cypress/downloads/
.cypress-cache/
node_modules/

# Dependencies — commit package*.json for reproducibility
# package.json
# package-lock.json
