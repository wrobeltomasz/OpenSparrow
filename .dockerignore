# Version control
.git
.gitignore
.gitattributes

# Docker / deploy configuration — used to build or run containers, never needed
# inside the image. docker-php-dev.ini is NOT excluded: the Dockerfile COPYs it.
Dockerfile
Dockerfile.standalone
docker-compose.yml
docker-compose.override.yml
docker-compose-production.yml
.dockerignore
nginx.conf
nginx.standalone.conf
supervisord.standalone.conf
railway.toml
render.yaml

# CI / GitHub
.github/

# AI assistant files
.claude/
CLAUDE.md

# Documentation (README, CONTRIBUTING, docs/ …); COPYING and COPYING.LESSER
# are intentionally NOT excluded — the LGPL v3 licence text ships with the image.
*.md
docs/

# Development tooling and tests
tests/
cypress/
cypress.config.js
.cypress-cache/
phpcs.xml
phpcs.phar
phpcbf.phar
phpunit.xml
.phpunit.result.cache
composer.json
composer.lock
vendor/
package.json
package-lock.json
node_modules/
scripts/
public/cypress_seed.php

# Secrets and instance-specific configuration — the container must start clean;
# config JSON is generated by setup.php or mounted, never baked into the image
.env
.env.*
config/*.json
!config/migrations.json
config/*.example
includes/.secret_salt

# Local runtime state — never bake user data into the image
storage/files/*
!storage/files/.gitkeep
!storage/files/.htaccess
storage/sessions/*
!storage/sessions/.gitkeep
!storage/sessions/.htaccess
storage/ratelimit/*
!storage/ratelimit/.htaccess
public/assets/img/uploads/*
!public/assets/img/uploads/.gitkeep
!public/assets/img/uploads/.htaccess

# Logs and temporary files
*.log
cache/
temp/
